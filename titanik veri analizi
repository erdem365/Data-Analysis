# 7. groupby ile analiz: Pclass'a göre ortalama yaş ve yaşayanların oranı
print("\n--- Yolcu Sınıfına Göre Ortalama Yaş ve Hayatta Kalma Oranları ---")
pclass_analysis = titanic_df.groupby('pclass').agg({
    'age': 'mean',
    'survived': 'mean'
}).rename(columns={'age': 'Ortalama Yaş', 'survived': 'Hayatta Kalma Oranı'})
print(pclass_analysis)

